# Puppeteer is only used by scripts/prerender.js, which can't run in hosts
# without Chrome's system libraries (e.g. the Vercel build image). Skip the
# ~150MB Chromium download on install to speed up CI/hosted builds. Prerender
# degrades gracefully when Chrome is absent (see scripts/prerender.js).
#
# To run prerender locally, install Chrome for Puppeteer once:
#   npx puppeteer browsers install chrome
puppeteer_skip_download=true
